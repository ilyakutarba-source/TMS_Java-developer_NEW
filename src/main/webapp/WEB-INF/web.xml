         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">
    <servlet>
        <servlet-name>timeServlet</servlet-name>
        <servlet-class>HomeWork24.task1.TimeServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>timeServlet</servlet-name>
        <url-pattern>/minsk</url-pattern>
        <url-pattern>/washington</url-pattern>
        <url-pattern>/beijing</url-pattern>
    </servlet-mapping>
